graph LR
    Cat["Chronos2 catalog"] -->|checkpoint ref| Ckpt["Resolved checkpoint<br/>(.onnx + metadata.json)"]
    Ckpt --> Backend["OnnxBackend<br/>(ONNX Runtime session)"]
    Backend --> Forecaster["Chronos2Forecaster"]

    subgraph Workflow["CustomForecastingWorkflow"]
        direction TB
        Sel["Selector<br/>(target + covariates)"] --> Forecaster --> Sort["QuantileSorter"]
    end

    Cfg["ForecastingWorkflowConfig"] -.->|create_forecasting_workflow| Workflow
    Workflow -->|wrapped by| Beam["FoundationModelBacktestForecaster"]

    classDef primary fill:#00D9C5,stroke:#1E3A5F,stroke-width:2px,color:#000
    classDef secondary fill:#1E3A5F,stroke:#00D9C5,stroke-width:2px,color:#fff
    classDef accent fill:#e6f7f5,stroke:#00D9C5,stroke-width:2px,color:#000
    classDef factory fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#000

    class Forecaster secondary
    class Sel,Sort primary
    class Cat,Ckpt,Backend,Beam accent
    class Cfg factory
